# Copy to .env and fill in if you want LLM-quality answers.
# Leave blank to run in fully-offline extractive mode (demo-safe, no internet needed).

# --- LLM provider: "anthropic", "openai", or "offline" ---
LLM_PROVIDER=anthropic

# Anthropic (recommended). Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI (alternative)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Retrieval ---
# Set to "1" to also use dense sentence-transformer embeddings (requires install).
USE_DENSE_EMBEDDINGS=0
